<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="fr.lhsa.controller.EventsController"
      alignment="CENTER"
      spacing="20">

    <Label text="Gestion des événements"
           style="-fx-font-size: 30px;"/>

    <Button text="Ajouter un événement"
            onAction="#showCreateEvent"/>

    <Button text="Supprimer"
            onAction="#deleteEvent"/>

    <TableView fx:id="eventTable"
               layoutX="20"
               layoutY="20"
               prefWidth="700"
               prefHeight="400">

        <columns>

            <TableColumn fx:id="idColumn"
                         text="ID"
                         prefWidth="100"/>

            <TableColumn fx:id="nameColumn"
                         text="Nom"
                         prefWidth="300"/>

            <TableColumn fx:id="dateColumn"
                         text="Date"
                         prefWidth="300"/>

        </columns>

    </TableView>


</VBox>