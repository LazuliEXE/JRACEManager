<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="fr.lhsa.controller.RacesController"
      spacing="20"
      alignment="CENTER">

    <Label text="Courses"
           style="-fx-font-size: 28px;" />

    <Button text="Ajouter une course"
            onAction="#showCreateRace"/>

    <TableView fx:id="raceTable"
               prefWidth="600"
               prefHeight="400">

        <columns>

            <TableColumn fx:id="idColumn"
                         text="ID"
                         prefWidth="100"/>

            <TableColumn fx:id="nameColumn"
                         text="Nom"
                         prefWidth="500"/>

        </columns>

    </TableView>

</VBox>